#include <iostream>
using namespace std;

struct LL_Node {
    int data;
    LL_Node* next;
};

LL_Node* List = NULL;

// INSERT at end (circular)
void insert(int val) {
    LL_Node* temp = new LL_Node;
    temp->data = val;

    if (List == NULL) {
        List = temp;
        temp->next = List;
    }
    else {
        LL_Node* cur = List;
        while (cur->next != List) {
            cur = cur->next;
        }
        cur->next = temp;
        temp->next = List;
    }
}

// DISPLAY
void display() {
    if (List == NULL) {
        cout << "List is empty" << endl;
        return;
    }

    LL_Node* cur = List;
    do {
        cout << cur->data << " -> ";
        cur = cur->next;
    } while (cur != List);

    cout << "(back to head)" << endl;
}

// SEARCH
bool search(int key) {
    if (List == NULL) return false;

    LL_Node* cur = List;
    do {
        if (cur->data == key)
            return true;
        cur = cur->next;
    } while (cur != List);

    return false;
}

// DELETE by value
void delt(int val) {
    if (List == NULL) {
        cout << "List is empty\n";
        return;
    }

    LL_Node* cur = List;
    LL_Node* prev = NULL;

    // single node case
    if (List->data == val && List->next == List) {
        delete List;
        List = NULL;
        return;
    }

    // deleting head
    if (List->data == val) {
        LL_Node* last = List;
        while (last->next != List)
            last = last->next;

        LL_Node* temp = List;
        List = List->next;
        last->next = List;
        delete temp;
        return;
    }

    // deleting other nodes
    prev = List;
    cur = List->next;

    while (cur != List) {
        if (cur->data == val) {
            prev->next = cur->next;
            delete cur;
            return;
        }
        prev = cur;
        cur = cur->next;
    }

    cout << "Value not found\n";
}

int main() {
    int val1, val2, val3;

    cout << "Enter first value: ";
    cin >> val1;

    cout << "Enter second value: ";
    cin >> val2;

    cout << "Enter third value: ";
    cin >> val3;

    insert(val1);
    insert(val2);
    insert(val3);

    cout << "\nCircular Linked List: ";
    display();

    int delVal;
    cout << "\nEnter value to delete: ";
    cin >> delVal;
    delt(delVal);

    cout << "\nAfter Deletion: ";
    display();

    int searchVal;
    cout << "\nEnter value to search: ";
    cin >> searchVal;

    if (search(searchVal))
        cout << "Value found in the list." << endl;
    else
        cout << "Value NOT found." << endl;

    return 0;
}
